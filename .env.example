# ── VoiceI Framework Configuration ──

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
LOG_LEVEL=info

# Authentication
API_KEY=your-api-key-here

# Database
DATABASE_URL=sqlite+aiosqlite:///./voicei.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/voicei

# Redis (optional, for caching)
# REDIS_URL=redis://localhost:6379/0

# ── LLM Providers ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# vLLM / LM Studio (OpenAI-compatible)
VLLM_BASE_URL=http://localhost:8080/v1
VLLM_API_KEY=

# ── Voice ──
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# CORS (comma-separated origins for the browser dashboard)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Pipeline definitions on disk
PIPELINES_DIR=pipelines

# Default models
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_STT_PROVIDER=whisper
DEFAULT_TTS_PROVIDER=openai
DEFAULT_TTS_MODEL=tts-1
DEFAULT_TTS_VOICE=alloy

# Dashboard (Vite) — set when API_KEY is not the dev default; must match server API_KEY
# VITE_API_KEY=your-api-key-here
